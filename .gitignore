# ─────────────────────────────────────
# Python cache & compiled files
# ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ─────────────────────────────────────
# Virtual environments
# ─────────────────────────────────────
venv/
env/
.venv/
ENV/

# ─────────────────────────────────────
# Environment variables
# ─────────────────────────────────────
.env
.env.*

# ─────────────────────────────────────
# Logs & runtime files
# ─────────────────────────────────────
*.log
*.out
*.err

# ─────────────────────────────────────
# OS-specific files
# ─────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────
# IDE / Editor files
# ─────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─────────────────────────────────────
# Build / distribution
# ─────────────────────────────────────
build/
dist/
*.egg-info/

# ─────────────────────────────────────
# Jupyter Notebook checkpoints
# ─────────────────────────────────────
.ipynb_checkpoints/

# ─────────────────────────────────────
# OpenCV / Video files (optional)
# Uncomment if you don't want to upload videos
# ─────────────────────────────────────
# *.mp4
# *.avi
# *.mov

# ─────────────────────────────────────
# Model weights (YOLO, etc.)
# ─────────────────────────────────────
*.pt
*.onnx
*.engine

# ─────────────────────────────────────
# Temporary files
# ─────────────────────────────────────
tmp/
temp/
*.tmp

# ─────────────────────────────────────
# CSV exports / session logs
# ─────────────────────────────────────
*.csv

# ─────────────────────────────────────
# Flask cache
# ─────────────────────────────────────
instance/
.webassets-cache

# ─────────────────────────────────────
# Coverage reports
# ─────────────────────────────────────
.coverage
htmlcov/

# ─────────────────────────────────────
# Misc
# ─────────────────────────────────────
*.bak
*.sqlite3